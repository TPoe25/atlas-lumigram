rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    // Post images are readable by signed-in users, writable by owner only.
    match /posts/{uid}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // Profile avatars are readable by signed-in users, writable by owner only.
    match /avatars/{uid}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }
  }
}
