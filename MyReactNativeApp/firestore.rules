rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isMe(uid) { return signedIn() && request.auth.uid == uid; }

    // POSTS
    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // FAVORITES
    match /favorites/{uid}/posts/{postId} {
      allow read, write: if isMe(uid);
    }

    // USER PROFILES (public readable, owner writable)
    match /profiles/{uid} {
      allow read: if signedIn();          // or: if true; if you want public profiles
      allow write: if isMe(uid);
    }

    // WORKOUT LOGS (owner only)
    match /workoutLogs/{logId} {
      allow read, create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // OPTIONAL: if you store logs nested per user:
    match /users/{uid}/logs/{logId} {
      allow read, write: if isMe(uid);
    }
  }
}
